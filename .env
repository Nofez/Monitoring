PROMETHEUS_IMAGE=prom/prometheus:v3.4.1
PROMETHEUS_YML=./prometheus/prometheus.yml
PROMETHEUS_TARGET=./prometheus/targets
PROMETHEUS_RULE=./prometheus/rules
PROMETHEUS_PORT=9090

ALERT_IMAGE=prom/alertmanager:v0.27.0
ALERT_YML=./alertmanager/alertmanager.yml
ALERT_PORT=9093

NODA_IMAGE=prom/node-exporter:v1.8.1
NODA_PORT=9100

BLACKBOX_IMAGE=prom/blackbox-exporter:v0.25.0

MYSQL_IMAGE=prom/mysqld-exporter:v0.15.1
MYSQL_NDWORK=./exporters/.my.cnf